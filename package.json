{
  "name": "gowater-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@gowater/web",
    "dev:mobile": "turbo dev --filter=@gowater/mobile",
    "lint": "turbo lint",
    "clean": "turbo clean && rm -rf node_modules"
  },
