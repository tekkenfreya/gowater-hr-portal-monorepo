      "id": "is-break-end",
      "name": "Break Ended?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [690, 820]
    },
    {
      "parameters": {
        "channel": "#attendance",
        "text": "=:white_check_mark: *Check In*\n\n*Employee:* {{ $json.data.employeeName }} ({{ $json.data.employeeId }})\n*Date:* {{ $json.data.date }}\n*Location:* {{ $json.data.workLocation }}\n*Time:* {{ new Date($json.timestamp).toLocaleTimeString('en-PH', { hour: '2-digit', minute: '2-digit', hour12: true }) }}{{ $json.data.notes ? '\\n*Notes:* ' + $json.data.notes : '' }}",
        "otherOptions": {
          "includeLinkToWorkflow": false
        }
      },
      "id": "slack-checkin",
      "name": "Slack: Check In",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.2,
      "position": [930, 100],
      "credentials": {
        "slackApi": {
          "id": "REPLACE_WITH_YOUR_SLACK_CREDENTIAL_ID",
          "name": "Slack Account"
        }
      }
    },
    {
      "parameters": {
        "channel": "#attendance",
        "text": "=:door: *Check Out*\n\n*Employee:* {{ $json.data.employeeName }} ({{ $json.data.employeeId }})\n*Date:* {{ $json.data.date }}\n*Total Hours:* {{ Number($json.data.totalHours).toFixed(2) }}h\n*Check Out:* {{ new Date($json.data.checkOutTime).toLocaleTimeString('en-PH', { hour: '2-digit', minute: '2-digit', hour12: true }) }}",
        "otherOptions": {
          "includeLinkToWorkflow": false
        }
