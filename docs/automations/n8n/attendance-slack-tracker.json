        }
      }
    },
    {
      "parameters": {
        "channel": "#attendance",
        "text": "=:arrow_forward: *Break Ended*\n\n*Employee:* {{ $json.data.employeeName }} ({{ $json.data.employeeId }})\n*Date:* {{ $json.data.date }}\n*Break Duration:* {{ Math.floor($json.data.breakDurationSeconds / 60) }} min\n*Total Break Today:* {{ Math.floor($json.data.totalBreakDuration / 60) }} min",
        "otherOptions": {
          "includeLinkToWorkflow": false
