{
  "expo": {
    "name": "GoWater Mobile",
    "slug": "gowater-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "gowater",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gowater.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.gowater.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "cameraPermission": "GoWater needs access to your camera to take check-in and check-out photos."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "GoWater needs access to your location to tag your check-in and check-out photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
